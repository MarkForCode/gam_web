{
  "name": "@gam/backstage",
  "version": "4.5.0",
  "private": true,
  "description": "Admin backstage application for GAM",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 umi build",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider umi build",
    "dev": "cross-env REACT_APP_ENV=dev MOCK=none PORT=8081 UMI_ENV=dev umi dev",
    "lint": "umi g tmp && yarn lint:js && yarn lint:style && yarn lint:prettier",
    "lint:fix": "eslint --fix --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src && yarn lint:style",
    "lint:js": "eslint --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:prettier": "prettier --check \"src/**/*\" --end-of-line auto",
    "lint:style": "stylelint --fix \"src/**/*.less\" --syntax less",
    "prettier": "prettier -c --write \"src/**/*\"",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^4.0.0",
    "@ant-design/pro-descriptions": "^1.2.0",
    "@ant-design/pro-form": "^1.3.0",
    "@ant-design/pro-layout": "^6.9.0",
    "@ant-design/pro-table": "^2.17.0",
    "@gam/shared": "*",
    "@umijs/route-utils": "^1.0.33",
    "ahooks": "^2.10.14",
    "antd": "^4.15.0",
    "classnames": "^2.2.6",
    "dva": "^2.4.0",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.11",
    "lodash-decorators": "^6.0.1",
    "moment": "^2.25.3",
    "numeral": "^2.0.6",
    "nzh": "^1.0.8",
    "omit.js": "^2.0.2",
    "react": "^16.14.0",
    "react-dev-inspector": "^1.1.1",
    "react-dom": "^16.14.0",
    "react-helmet-async": "^1.0.4",
    "react-markdown": "^8.0.3",
    "react-quill": "^1.3.5",
    "react-router": "^4.3.1",
    "umi": "^3.4.1",
    "umi-request": "^1.0.8"
  },
  "devDependencies": {
    "@ant-design/pro-cli": "^1.0.28",
    "@types/classnames": "^2.2.7",
    "@types/express": "^4.17.0",
    "@types/history": "^4.7.2",
    "@types/jest": "^26.0.0",
    "@types/lodash": "^4.14.144",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/react-helmet": "^6.1.0",
    "@umijs/fabric": "^2.5.1",
    "@umijs/plugin-blocks": "^2.0.5",
    "@umijs/plugin-esbuild": "^1.0.1",
    "@umijs/preset-ant-design-pro": "^1.2.0",
    "@umijs/preset-react": "^1.4.8",
    "@umijs/preset-ui": "^2.2.9",
    "@umijs/yorkie": "^2.0.3",
    "cross-env": "^7.0.0",
    "eslint": "^7.1.0",
    "prettier": "^2.0.1",
    "stylelint": "^13.0.0",
    "typescript": "^4.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
