{
  "name": "gam-monorepo",
  "version": "4.5.0",
  "private": true,
  "description": "GAM - Monorepo with backstage and user-web applications",
  "workspaces": [
    "packages/shared",
    "packages/backstage",
    "packages/user-web"
  ],
  "scripts": {
    "bootstrap": "yarn install",
    "build": "yarn workspaces run build",
    "build:backstage": "yarn workspace @gam/backstage build",
    "build:user-web": "yarn workspace @gam/user-web build",
    "clean": "yarn workspaces run clean && rm -rf node_modules",
    "dev": "yarn workspaces run dev",
    "dev:backstage": "yarn workspace @gam/backstage dev",
    "dev:user-web": "yarn workspace @gam/user-web dev",
    "docker:build": "docker-compose build",
    "docker:down": "docker-compose down",
    "docker:up": "docker-compose up",
    "lint": "yarn workspaces run lint",
    "lint:fix": "yarn workspaces run lint:fix",
    "test": "yarn workspaces run test"
  },
  "devDependencies": {
    "cross-env": "^7.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
